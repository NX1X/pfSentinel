{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["dependencies", "security"]
  },
  "packageRules": [
    {
      "description": "Group all non-major Python dependency updates",
      "matchManagers": ["pip_requirements", "pip_setup", "pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python minor/patch dependencies",
      "automerge": true
    },
    {
      "description": "Major version bumps require manual review",
      "matchManagers": ["pip_requirements", "pip_setup", "pep621"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Pin and group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions minor/patch",
      "automerge": true
    },
    {
      "description": "GitHub Actions major updates require review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Security-critical packages: always update promptly",
      "matchPackageNames": ["paramiko", "cryptography", "requests", "urllib3"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "schedule": ["at any time"],
      "prPriority": 10
    },
    {
      "description": "Keep lock file in sync with pyproject.toml updates",
      "matchManagers": ["pip-compile"],
      "groupName": "lock file maintenance",
      "automerge": true
    }
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "America/New_York",
  "prConcurrentLimit": 5
}
